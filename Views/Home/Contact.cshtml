@model ContactMessage
@{
    ViewData["Title"] = "Contact Us";
}

<section class="page-header">
    <div class="container">
        <h1>Contact Us</h1>
        <p>Get in touch with our community</p>
    </div>
</section>

<section class="contact-detailed">
    <div class="container">
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success">
                <i class="fas fa-check-circle"></i>
                @TempData["SuccessMessage"]
            </div>
        }

        <div class="contact-grid">
            <div class="contact-info">
                <h3>Get in Touch</h3>
                <div class="contact-item">
                    <i class="fas fa-map-marker-alt"></i>
                    <div>
                        <h4>Address</h4>
                        <p>123 Community Center Drive<br>Minneapolis, MN 55404</p>
                    </div>
                </div>
                <div class="contact-item">
                    <i class="fas fa-phone"></i>
                    <div>
                        <h4>Phone</h4>
                        <p>(612) 555-0123</p>
                    </div>
                </div>
                <div class="contact-item">
                    <i class="fas fa-envelope"></i>
                    <div>
                        <h4>Email</h4>
                        <p>info@gambianmuslimcommunity.org</p>
                    </div>
                </div>
                <div class="contact-item">
                    <i class="fas fa-clock"></i>
                    <div>
                        <h4>Office Hours</h4>
                        <p>Monday - Friday: 9:00 AM - 5:00 PM<br>
                           Saturday: 10:00 AM - 3:00 PM<br>
                           Sunday: After Jummah Prayer</p>
                    </div>
                </div>

                <div class="additional-contacts">
                    <h4>Department Contacts</h4>
                    <p><strong>Imam/Religious Questions:</strong> imam@gambianmuslimcommunity.org</p>
                    <p><strong>Events Coordination:</strong> events@gambianmuslimcommunity.org</p>
                    <p><strong>Youth Programs:</strong> youth@gambianmuslimcommunity.org</p>
                    <p><strong>Women's Programs:</strong> women@gambianmuslimcommunity.org</p>
                    <p><strong>Education:</strong> education@gambianmuslimcommunity.org</p>
                </div>
            </div>

            <div class="contact-form-section">
                <h3>Send us a Message</h3>
                <form asp-action="Contact" method="post" class="contact-form">
                    @Html.AntiForgeryToken()
                    
                    <div class="form-group">
                        <label asp-for="Name">Name *</label>
                        <input asp-for="Name" class="form-control" />
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="Email">Email *</label>
                        <input asp-for="Email" class="form-control" />
                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="Subject">Subject</label>
                        <input asp-for="Subject" class="form-control" />
                        <span asp-validation-for="Subject" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="Message">Message *</label>
                        <textarea asp-for="Message" rows="5" class="form-control"></textarea>
                        <span asp-validation-for="Message" class="text-danger"></span>
                    </div>

                    <button type="submit" class="btn btn-primary">
                        <i class="fas fa-paper-plane"></i> Send Message
                    </button>
                </form>
            </div>
        </div>

        <div class="directions-section">
            <h3>Directions & Parking</h3>
            <div class="directions-grid">
                <div class="direction-item">
                    <i class="fas fa-car"></i>
                    <div>
                        <h4>By Car</h4>
                        <p>Free parking is available in our lot. Take Exit 15 from I-35W and follow Community Center Drive for 2 miles.</p>
                    </div>
                </div>
                <div class="direction-item">
                    <i class="fas fa-bus"></i>
                    <div>
                        <h4>Public Transportation</h4>
                        <p>Take Metro Bus Route 18 or 22. The Community Center Drive stop is directly in front of our building.</p>
                    </div>
                </div>
                <div class="direction-item">
                    <i class="fas fa-wheelchair"></i>
                    <div>
                        <h4>Accessibility</h4>
                        <p>Our facility is fully wheelchair accessible with ramps, elevators, and accessible restrooms.</p>
                    </div>
                </div>
                <div class="direction-item">
                    <i class="fas fa-clock"></i>
                    <div>
                        <h4>Prayer Times Access</h4>
                        <p>The mosque is open 24/7 for prayers. Main office hours are listed above for administrative matters.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}