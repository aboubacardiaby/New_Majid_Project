@model MasjidDonation
@{
    ViewData["Title"] = "Donate to " + Model.MasjidProject?.Title;
}

<section class="page-header">
    <div class="container">
        <h1><i class="fas fa-heart"></i> Make a Donation</h1>
        <p>Support the @Model.MasjidProject?.Title</p>
    </div>
</section>

<section class="donation-form-section">
    <div class="container">
        <div class="donation-grid">
            <div class="donation-form-card">
                <div class="form-header">
                    <h2>Your Donation Details</h2>
                    <p>May Allah (SWT) reward you for your generous contribution</p>
                </div>

                <form asp-action="Donate" method="post" class="donation-form">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="MasjidProjectId" />

                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div class="alert alert-error">
                            <i class="fas fa-exclamation-triangle"></i>
                            Please correct the errors below and try again.
                        </div>
                    }

                    <div class="form-section">
                        <h3><i class="fas fa-dollar-sign"></i> Donation Amount</h3>
                        <div class="amount-selection">
                            <div class="preset-amounts">
                                <button type="button" class="amount-btn" data-amount="50">$50</button>
                                <button type="button" class="amount-btn" data-amount="100">$100</button>
                                <button type="button" class="amount-btn" data-amount="250">$250</button>
                                <button type="button" class="amount-btn" data-amount="500">$500</button>
                                <button type="button" class="amount-btn" data-amount="1000">$1,000</button>
                            </div>
                            <div class="custom-amount">
                                <label asp-for="Amount">Custom Amount *</label>
                                <div class="amount-input">
                                    <span class="currency">$</span>
                                    <input asp-for="Amount" type="number" step="0.01" min="1" placeholder="0.00" class="form-control" />
                                </div>
                                <span asp-validation-for="Amount" class="text-danger"></span>
                            </div>
                        </div>
                    </div>

                    <div class="form-section">
                        <h3><i class="fas fa-user"></i> Donor Information</h3>
                        <div class="form-row">
                            <div class="form-group">
                                <label asp-for="DonorName">Full Name *</label>
                                <input asp-for="DonorName" class="form-control" placeholder="Your full name" />
                                <span asp-validation-for="DonorName" class="text-danger"></span>
                            </div>
                            <div class="form-group">
                                <label asp-for="Email">Email Address</label>
                                <input asp-for="Email" class="form-control" placeholder="your.email@example.com" />
                                <span asp-validation-for="Email" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="form-group">
                            <label asp-for="Message">Message/Note (Optional)</label>
                            <textarea asp-for="Message" rows="3" class="form-control" placeholder="Share why you're supporting this project..."></textarea>
                            <span asp-validation-for="Message" class="text-danger"></span>
                        </div>

                        <div class="form-group">
                            <div class="checkbox-group">
                                <input asp-for="IsAnonymous" type="checkbox" class="form-check-input" />
                                <label asp-for="IsAnonymous" class="form-check-label">
                                    Make this an anonymous donation
                                </label>
                            </div>
                            <small class="form-text">If checked, your name will not be displayed publicly</small>
                        </div>
                    </div>

                    <div class="form-section">
                        <h3><i class="fas fa-credit-card"></i> Payment Method</h3>
                        <div class="payment-methods">
                            <div class="payment-option">
                                <input type="radio" name="PaymentMethod" value="PayPal" id="paypal" checked />
                                <label for="paypal">
                                    <i class="fab fa-paypal"></i>
                                    PayPal - Secure Online Payment
                                </label>
                            </div>
                            <div class="payment-option">
                                <input type="radio" name="PaymentMethod" value="Credit Card" id="credit-card" />
                                <label for="credit-card">
                                    <i class="fas fa-credit-card"></i>
                                    Credit/Debit Card (Coming Soon)
                                </label>
                            </div>
                            <div class="payment-option">
                                <input type="radio" name="PaymentMethod" value="Bank Transfer" id="bank-transfer" />
                                <label for="bank-transfer">
                                    <i class="fas fa-university"></i>
                                    Bank Transfer (Coming Soon)
                                </label>
                            </div>
                            <div class="payment-option">
                                <input type="radio" name="PaymentMethod" value="Cash" id="cash" />
                                <label for="cash">
                                    <i class="fas fa-money-bill-alt"></i>
                                    Cash (In-Person)
                                </label>
                            </div>
                        </div>
                        
                        <div class="paypal-info">
                            <div class="paypal-benefits">
                                <h4><i class="fab fa-paypal"></i> Why PayPal?</h4>
                                <ul>
                                    <li><i class="fas fa-shield-alt"></i> Bank-level security and encryption</li>
                                    <li><i class="fas fa-credit-card"></i> Pay with PayPal balance, bank, or card</li>
                                    <li><i class="fas fa-mobile-alt"></i> Mobile-friendly checkout</li>
                                    <li><i class="fas fa-undo"></i> Buyer protection included</li>
                                </ul>
                            </div>
                        </div>
                    </div>

                    <div class="form-actions">
                        <button type="button" id="paypal-donate-btn" class="btn btn-paypal btn-lg btn-block">
                            <i class="fab fa-paypal"></i> Donate with PayPal
                        </button>
                        <button type="submit" id="regular-donate-btn" class="btn btn-primary btn-lg btn-block" style="display: none;">
                            <i class="fas fa-heart"></i> Complete Donation
                        </button>
                        <a asp-action="MasjidProject" asp-route-id="@Model.MasjidProjectId" class="btn btn-secondary">
                            <i class="fas fa-arrow-left"></i> Back to Project
                        </a>
                    </div>
                </form>
            </div>

            <div class="donation-summary">
                <div class="project-summary">
                    <h3>@Model.MasjidProject?.Title</h3>
                    <div class="project-progress">
                        <div class="progress-bar">
                            <div class="progress-fill" style="width: @Model.MasjidProject?.ProgressPercentage%"></div>
                        </div>
                        <div class="progress-stats">
                            <span>${@Model.MasjidProject?.CurrentAmount:N0} raised</span>
                            <span>${@Model.MasjidProject?.TargetAmount:N0} goal</span>
                        </div>
                    </div>
                </div>

                <div class="donation-impact">
                    <h4>Your Impact</h4>
                    <div class="impact-examples">
                        <div class="impact-example">
                            <span class="amount">$50</span>
                            <span class="description">Sponsor prayer rugs</span>
                        </div>
                        <div class="impact-example">
                            <span class="amount">$100</span>
                            <span class="description">Support classroom equipment</span>
                        </div>
                        <div class="impact-example">
                            <span class="amount">$250</span>
                            <span class="description">Contribute to sound system</span>
                        </div>
                        <div class="impact-example">
                            <span class="amount">$500</span>
                            <span class="description">Help with materials</span>
                        </div>
                    </div>
                </div>

                <div class="islamic-reminder">
                    <div class="reminder-content">
                        <i class="fas fa-quote-left"></i>
                        <p>"The believer's shade on the Day of Resurrection will be his charity."</p>
                        <cite>- Prophet Muhammad (PBUH)</cite>
                    </div>
                </div>

                <div class="security-info">
                    <h4><i class="fas fa-shield-alt"></i> Secure Donation</h4>
                    <ul>
                        <li><i class="fas fa-check"></i> SSL encrypted connection</li>
                        <li><i class="fas fa-check"></i> Your data is protected</li>
                        <li><i class="fas fa-check"></i> 100% goes to the project</li>
                        <li><i class="fas fa-check"></i> Tax-deductible receipt</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const amountButtons = document.querySelectorAll('.amount-btn');
            const amountInput = document.querySelector('input[name="Amount"]');
            const paymentMethodRadios = document.querySelectorAll('input[name="PaymentMethod"]');
            const paypalButton = document.getElementById('paypal-donate-btn');
            const regularButton = document.getElementById('regular-donate-btn');

            // Amount selection functionality
            amountButtons.forEach(button => {
                button.addEventListener('click', function() {
                    amountButtons.forEach(btn => btn.classList.remove('active'));
                    this.classList.add('active');
                    const amount = this.dataset.amount;
                    amountInput.value = amount;
                });
            });

            // Clear active buttons when custom amount is entered
            amountInput.addEventListener('input', function() {
                amountButtons.forEach(btn => btn.classList.remove('active'));
            });

            // Payment method selection
            paymentMethodRadios.forEach(radio => {
                radio.addEventListener('change', function() {
                    if (this.value === 'PayPal') {
                        paypalButton.style.display = 'block';
                        regularButton.style.display = 'none';
                    } else {
                        paypalButton.style.display = 'none';
                        regularButton.style.display = 'block';
                    }
                });
            });

            // PayPal payment handling
            paypalButton.addEventListener('click', function() {
                const form = document.querySelector('.donation-form');
                const formData = new FormData(form);
                
                // Validate required fields
                const amount = formData.get('Amount');
                const donorName = formData.get('DonorName');
                
                if (!amount || amount <= 0) {
                    alert('Please enter a valid donation amount.');
                    return;
                }
                
                if (!donorName) {
                    alert('Please enter your full name.');
                    return;
                }

                // Disable button and show loading
                paypalButton.disabled = true;
                paypalButton.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Processing...';

                // Prepare payment data
                const paymentData = {
                    MasjidProjectId: parseInt(formData.get('MasjidProjectId')),
                    Amount: parseFloat(amount),
                    DonorName: donorName,
                    Email: formData.get('Email') || '',
                    Message: formData.get('Message') || '',
                    IsAnonymous: formData.get('IsAnonymous') === 'true'
                };

                // Create PayPal payment
                fetch('/Home/CreatePayPalPayment', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
                    },
                    body: JSON.stringify(paymentData)
                })
                .then(response => response.json())
                .then(result => {
                    if (result.success && result.approvalUrl) {
                        // Redirect to PayPal
                        window.location.href = result.approvalUrl;
                    } else {
                        alert('Error creating PayPal payment: ' + (result.message || 'Unknown error'));
                        resetPayPalButton();
                    }
                })
                .catch(error => {
                    console.error('PayPal payment error:', error);
                    alert('Error processing PayPal payment. Please try again.');
                    resetPayPalButton();
                });
            });

            function resetPayPalButton() {
                paypalButton.disabled = false;
                paypalButton.innerHTML = '<i class="fab fa-paypal"></i> Donate with PayPal';
            }
        });
    </script>
    
    <style>
        .btn-paypal {
            background: linear-gradient(135deg, #0070ba, #005ea6);
            color: white;
            border: none;
            font-weight: 600;
            text-transform: none;
            transition: all 0.3s ease;
            position: relative;
            overflow: hidden;
        }

        .btn-paypal:hover {
            background: linear-gradient(135deg, #005ea6, #004c87);
            transform: translateY(-2px);
            box-shadow: 0 8px 25px rgba(0, 112, 186, 0.4);
            color: white;
        }

        .btn-paypal:active {
            transform: translateY(0);
        }

        .btn-paypal:disabled {
            background: #ccc;
            cursor: not-allowed;
            transform: none;
            box-shadow: none;
        }

        .payment-methods {
            display: grid;
            gap: 15px;
            margin-bottom: 30px;
        }

        .payment-option {
            position: relative;
        }

        .payment-option input[type="radio"] {
            position: absolute;
            opacity: 0;
            width: 0;
            height: 0;
        }

        .payment-option label {
            display: flex;
            align-items: center;
            padding: 15px 20px;
            border: 2px solid #e0e0e0;
            border-radius: 12px;
            cursor: pointer;
            transition: all 0.3s ease;
            background: white;
            font-weight: 500;
        }

        .payment-option label:hover {
            border-color: #0070ba;
            background: #f8f9ff;
        }

        .payment-option input[type="radio"]:checked + label {
            border-color: #0070ba;
            background: linear-gradient(135deg, #f8f9ff, #e8f2ff);
            color: #0070ba;
            box-shadow: 0 4px 12px rgba(0, 112, 186, 0.1);
        }

        .payment-option label i {
            font-size: 1.5em;
            margin-right: 12px;
            min-width: 30px;
        }

        .payment-option input[type="radio"]:checked + label i {
            color: #0070ba;
        }

        .paypal-info {
            background: linear-gradient(135deg, #f8f9ff, #e8f2ff);
            border: 1px solid #0070ba;
            border-radius: 12px;
            padding: 20px;
            margin-top: 20px;
        }

        .paypal-benefits h4 {
            color: #0070ba;
            margin-bottom: 15px;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .paypal-benefits ul {
            list-style: none;
            padding: 0;
            margin: 0;
        }

        .paypal-benefits li {
            display: flex;
            align-items: center;
            padding: 8px 0;
            color: #333;
        }

        .paypal-benefits li i {
            color: #0070ba;
            margin-right: 12px;
            min-width: 20px;
        }

        .form-actions {
            display: flex;
            flex-direction: column;
            gap: 15px;
            margin-top: 30px;
        }

        @@media (min-width: 768px) {
            .form-actions {
                flex-direction: row;
                justify-content: space-between;
                align-items: center;
            }

            .btn-lg {
                flex: 1;
                margin-right: 15px;
            }

            .btn-secondary {
                flex: none;
                margin-right: 0;
            }
        }

        .donation-grid {
            display: grid;
            gap: 30px;
            margin-top: 30px;
        }

        @@media (min-width: 1024px) {
            .donation-grid {
                grid-template-columns: 2fr 1fr;
                gap: 40px;
            }
        }

        .fa-spin {
            animation: fa-spin 2s infinite linear;
        }

        @@keyframes fa-spin {
            0% { transform: rotate(0deg); }
            100% { transform: rotate(360deg); }
        }
    </style>
}