@model MasjidProject
@{
    ViewData["Title"] = Model.Title;
    var progressPct = Math.Min((double)Model.ProgressPercentage, 100);
}

@* ─── Hero ─────────────────────────────────────────────────────────────────── *@
<section class="mp-hero">
    <div class="mp-hero__overlay"></div>
    <div class="mp-hero__bg" style="background-image:url('@(string.IsNullOrEmpty(Model.ImageUrl) ? "/images/masjid-project.jpg" : Model.ImageUrl)')"></div>
    <div class="mp-hero__content container">
        <span class="mp-hero__badge"><i class="fas fa-mosque"></i> @Model.Status</span>
        <h1 class="mp-hero__title">@Model.Title</h1>
        <p class="mp-hero__sub">Building a spiritual home for our Gambian Muslim Community in Minnesota</p>
        <div class="mp-hero__stats">
            <div class="mp-stat">
                <strong>$@Model.CurrentAmount.ToString("N0")</strong>
                <span>Raised</span>
            </div>
            <div class="mp-stat-divider"></div>
            <div class="mp-stat">
                <strong>@Model.ProgressPercentage%</strong>
                <span>Funded</span>
            </div>
            <div class="mp-stat-divider"></div>
            <div class="mp-stat">
                <strong>@Model.DaysRemaining</strong>
                <span>Days Left</span>
            </div>
        </div>
        <div class="mp-hero__progress">
            <div class="mp-hero__progress-bar" style="width:@progressPct%"></div>
        </div>
        <a asp-action="Donate" asp-route-id="@Model.Id" class="btn btn-gold btn-lg">
            <i class="fas fa-heart"></i> Donate Now — Help Build Our Masjid
        </a>
    </div>
</section>

@* ─── Alerts ───────────────────────────────────────────────────────────────── *@
@if (TempData["SuccessMessage"] != null)
{
    <div class="container mt-3">
        <div class="alert alert-success">
            <i class="fas fa-check-circle"></i> @TempData["SuccessMessage"]
        </div>
    </div>
}

@* ─── Main grid ────────────────────────────────────────────────────────────── *@
<section class="mp-body">
    <div class="container">
        <div class="mp-grid">

            @* ── Left column ── *@
            <div class="mp-main">

                @* Project Overview *@
                <div class="mp-card">
                    <h2 class="mp-card__title"><i class="fas fa-info-circle"></i> Project Overview</h2>
                    <p class="mp-overview__text">@Model.Description</p>
                    <div class="mp-details-row">
                        <div class="mp-detail">
                            <i class="fas fa-map-marker-alt"></i>
                            <div>
                                <h4>Location</h4>
                                <p>@Model.Location</p>
                            </div>
                        </div>
                        <div class="mp-detail">
                            <i class="fas fa-calendar-check"></i>
                            <div>
                                <h4>Target Completion</h4>
                                <p>@(Model.TargetCompletionDate?.ToString("MMMM yyyy") ?? "To be determined")</p>
                            </div>
                        </div>
                        <div class="mp-detail">
                            <i class="fas fa-tasks"></i>
                            <div>
                                <h4>Phase</h4>
                                <p>@Model.Status</p>
                            </div>
                        </div>
                    </div>
                </div>

                @* Photo Gallery *@
                <div class="mp-card">
                    <h2 class="mp-card__title"><i class="fas fa-images"></i> Project Gallery</h2>
                    <p class="mp-card__sub">Progress photos and site images</p>
                    <div class="mp-gallery">
                        <div class="mp-gallery__main" id="galleryMain">
                            <img src="/images/masjid-gallery-1.jpg"
                                 onerror="this.src='/images/masjid-project.jpg'"
                                 alt="Masjid project main photo"
                                 id="galleryMainImg" />
                            <div class="mp-gallery__caption" id="galleryCaption">Site preparation — Phase 1</div>
                        </div>
                        <div class="mp-gallery__thumbs">
                            <div class="mp-gallery__thumb active" onclick="setGalleryImg(this, '/images/masjid-gallery-1.jpg', 'Site preparation — Phase 1')">
                                <img src="/images/masjid-gallery-1.jpg" onerror="this.src='/images/masjid-project.jpg'" alt="Site preparation" />
                            </div>
                            <div class="mp-gallery__thumb" onclick="setGalleryImg(this, '/images/masjid-gallery-2.jpg', 'Foundation work in progress')">
                                <img src="/images/masjid-gallery-2.jpg" onerror="this.src='/images/masjid-project.jpg'" alt="Foundation work" />
                            </div>
                            <div class="mp-gallery__thumb" onclick="setGalleryImg(this, '/images/masjid-gallery-3.jpg', 'Community fundraising event')">
                                <img src="/images/masjid-gallery-3.jpg" onerror="this.src='/images/masjid-project.jpg'" alt="Fundraising event" />
                            </div>
                            <div class="mp-gallery__thumb" onclick="setGalleryImg(this, '/images/masjid-gallery-4.jpg', 'Land survey and planning')">
                                <img src="/images/masjid-gallery-4.jpg" onerror="this.src='/images/masjid-project.jpg'" alt="Land survey" />
                            </div>
                            <div class="mp-gallery__thumb" onclick="setGalleryImg(this, '/images/masjid-gallery-5.jpg', 'Architect\'s rendering')">
                                <img src="/images/masjid-gallery-5.jpg" onerror="this.src='/images/masjid-project.jpg'" alt="Architect rendering" />
                            </div>
                            <div class="mp-gallery__thumb" onclick="setGalleryImg(this, '/images/masjid-gallery-6.jpg', 'Community gathering at current location')">
                                <img src="/images/masjid-gallery-6.jpg" onerror="this.src='/images/masjid-project.jpg'" alt="Community gathering" />
                            </div>
                        </div>
                    </div>
                </div>

                @* Video Section *@
                <div class="mp-card">
                    <h2 class="mp-card__title"><i class="fas fa-video"></i> Project Videos</h2>
                    <p class="mp-card__sub">Watch our community updates and announcements</p>
                    <div class="mp-videos">
                        <div class="mp-video-tabs">
                            <button class="mp-video-tab active" onclick="switchVideo(this, 'video1')">
                                <i class="fas fa-play-circle"></i> Imam's Message
                            </button>
                            <button class="mp-video-tab" onclick="switchVideo(this, 'video2')">
                                <i class="fas fa-play-circle"></i> Site Walkthrough
                            </button>
                            <button class="mp-video-tab" onclick="switchVideo(this, 'video3')">
                                <i class="fas fa-play-circle"></i> Community Appeal
                            </button>
                        </div>

                        <div class="mp-video-panel active" id="video1">
                            <div class="mp-video-wrap">
                                <iframe src="https://www.youtube.com/embed/videoseries?list=PLbpi6ZahtOH6Ar_3GPy3workbAsqXhg0"
                                        title="Imam's Message"
                                        frameborder="0"
                                        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                                        allowfullscreen></iframe>
                            </div>
                            <div class="mp-video-info">
                                <h4>Message from Our Imam</h4>
                                <p>Imam Abdullah Jallow shares the vision for the new masjid and the importance of this project for our community.</p>
                            </div>
                        </div>

                        <div class="mp-video-panel" id="video2">
                            <div class="mp-video-wrap">
                                <iframe src="https://www.youtube.com/embed/dQw4w9WgXcQ"
                                        title="Site Walkthrough"
                                        frameborder="0"
                                        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                                        allowfullscreen></iframe>
                            </div>
                            <div class="mp-video-info">
                                <h4>Site Walkthrough</h4>
                                <p>Take a tour of the building site in Minneapolis, MN, and see how your donations are being put to work.</p>
                            </div>
                        </div>

                        <div class="mp-video-panel" id="video3">
                            <div class="mp-video-wrap">
                                <iframe src="https://www.youtube.com/embed/dQw4w9WgXcQ"
                                        title="Community Appeal"
                                        frameborder="0"
                                        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                                        allowfullscreen></iframe>
                            </div>
                            <div class="mp-video-info">
                                <h4>Community Fundraising Appeal</h4>
                                <p>Members of the Gambian Muslim Community share why this masjid means so much to them and their families.</p>
                            </div>
                        </div>
                    </div>
                </div>

                @* Latest Updates *@
                @if (!string.IsNullOrEmpty(Model.Updates))
                {
                    <div class="mp-card mp-updates">
                        <h2 class="mp-card__title"><i class="fas fa-bullhorn"></i> Latest Update</h2>
                        <div class="mp-update-body">
                            <div class="mp-update-icon"><i class="fas fa-mosque"></i></div>
                            <div>
                                <p>@Model.Updates</p>
                                <small><i class="fas fa-clock"></i> @Model.CreatedDate.ToString("MMMM d, yyyy")</small>
                            </div>
                        </div>
                    </div>
                }

                @* Masjid Features *@
                <div class="mp-card">
                    <h2 class="mp-card__title"><i class="fas fa-building"></i> What the Masjid Will Include</h2>
                    <div class="mp-features">
                        <div class="mp-feature">
                            <div class="mp-feature__icon"><i class="fas fa-pray"></i></div>
                            <h4>Main Prayer Hall</h4>
                            <p>Spacious area for daily prayers and Jummah congregation</p>
                        </div>
                        <div class="mp-feature">
                            <div class="mp-feature__icon"><i class="fas fa-female"></i></div>
                            <h4>Women's Prayer Area</h4>
                            <p>Dedicated space for sisters with proper facilities</p>
                        </div>
                        <div class="mp-feature">
                            <div class="mp-feature__icon"><i class="fas fa-graduation-cap"></i></div>
                            <h4>Education Rooms</h4>
                            <p>Classrooms for Quran studies and Islamic education</p>
                        </div>
                        <div class="mp-feature">
                            <div class="mp-feature__icon"><i class="fas fa-utensils"></i></div>
                            <h4>Community Kitchen</h4>
                            <p>Facilities for iftar and community meals</p>
                        </div>
                        <div class="mp-feature">
                            <div class="mp-feature__icon"><i class="fas fa-car"></i></div>
                            <h4>Parking Facilities</h4>
                            <p>Adequate parking for community members</p>
                        </div>
                        <div class="mp-feature">
                            <div class="mp-feature__icon"><i class="fas fa-wheelchair"></i></div>
                            <h4>Accessibility</h4>
                            <p>Full accessibility compliance for all community members</p>
                        </div>
                    </div>
                </div>
            </div>

            @* ── Right sidebar ── *@
            <aside class="mp-sidebar">

                @* Fundraising card *@
                <div class="mp-fund-card">
                    <div class="mp-fund-card__header">
                        <h3>Fundraising Progress</h3>
                    </div>
                    <div class="mp-fund-card__body">
                        <div class="mp-fund-amounts">
                            <div>
                                <span class="mp-fund-raised">$@Model.CurrentAmount.ToString("N0")</span>
                                <span class="mp-fund-label">raised</span>
                            </div>
                            <div class="mp-fund-pct">@Model.ProgressPercentage%</div>
                        </div>
                        <div class="mp-fund-bar">
                            <div class="mp-fund-bar__fill" style="width:@progressPct%"></div>
                        </div>
                        <div class="mp-fund-goal">
                            of <strong>$@Model.TargetAmount.ToString("N0")</strong> goal
                        </div>
                        <div class="mp-fund-meta">
                            <div class="mp-fund-meta__item">
                                <i class="fas fa-clock"></i>
                                <strong>@Model.DaysRemaining</strong>
                                <span>days left</span>
                            </div>
                            <div class="mp-fund-meta__item">
                                <i class="fas fa-dollar-sign"></i>
                                <strong>$@((Model.TargetAmount - Model.CurrentAmount).ToString("N0"))</strong>
                                <span>still needed</span>
                            </div>
                        </div>
                        <a asp-action="Donate" asp-route-id="@Model.Id" class="btn btn-gold btn-block mt-2">
                            <i class="fas fa-heart"></i> Donate Now
                        </a>
                        <p class="mp-fund-secure">
                            <i class="fas fa-shield-alt"></i> Secure & transparent donation
                        </p>
                    </div>
                </div>

                @* Impact tiers *@
                <div class="mp-impact-card">
                    <h4><i class="fas fa-hand-holding-heart"></i> Your Impact</h4>
                    <ul class="mp-impact-list">
                        <li>
                            <span class="mp-impact-amt">$50</span>
                            <span>Prayer rugs for the masjid</span>
                        </li>
                        <li>
                            <span class="mp-impact-amt">$100</span>
                            <span>Classroom equipment</span>
                        </li>
                        <li>
                            <span class="mp-impact-amt">$250</span>
                            <span>Sound system contribution</span>
                        </li>
                        <li>
                            <span class="mp-impact-amt">$500</span>
                            <span>Construction materials</span>
                        </li>
                        <li>
                            <span class="mp-impact-amt">$1,000</span>
                            <span>Sponsor a section of the building</span>
                        </li>
                    </ul>
                </div>

                @* Share *@
                <div class="mp-share-card">
                    <h4><i class="fas fa-share-alt"></i> Spread the Word</h4>
                    <p>Share this project with family and friends</p>
                    <div class="mp-share-btns">
                        <a href="https://www.facebook.com/sharer/sharer.php?u=@Uri.EscapeDataString(Context.Request.Scheme + "://" + Context.Request.Host + Context.Request.Path)"
                           target="_blank" class="mp-share-btn mp-share-btn--fb">
                            <i class="fab fa-facebook-f"></i> Facebook
                        </a>
                        <a href="https://wa.me/?text=@Uri.EscapeDataString("Support our Masjid project: " + Context.Request.Scheme + "://" + Context.Request.Host + Context.Request.Path)"
                           target="_blank" class="mp-share-btn mp-share-btn--wa">
                            <i class="fab fa-whatsapp"></i> WhatsApp
                        </a>
                        <a href="https://twitter.com/intent/tweet?text=@Uri.EscapeDataString("Help us build a Masjid! " + Model.Title)&url=@Uri.EscapeDataString(Context.Request.Scheme + "://" + Context.Request.Host + Context.Request.Path)"
                           target="_blank" class="mp-share-btn mp-share-btn--tw">
                            <i class="fab fa-twitter"></i> Twitter
                        </a>
                        <button class="mp-share-btn mp-share-btn--copy" onclick="copyLink()">
                            <i class="fas fa-link"></i> Copy Link
                        </button>
                    </div>
                </div>
            </aside>
        </div>
    </div>
</section>

@* ─── Hadith banner ────────────────────────────────────────────────────────── *@
<section class="mp-hadith">
    <div class="container">
        <div class="mp-hadith__inner">
            <i class="fas fa-mosque mp-hadith__icon"></i>
            <blockquote>
                "Whoever builds a mosque for Allah, Allah will build for him a house like it in Paradise."
                <cite>— Prophet Muhammad ﷺ (Bukhari & Muslim)</cite>
            </blockquote>
        </div>
    </div>
</section>

@* ─── How to help ──────────────────────────────────────────────────────────── *@
<section class="mp-support">
    <div class="container">
        <h2 class="mp-support__title">Join Us in This Noble Cause</h2>
        <div class="mp-support-grid">
            <div class="mp-support-item">
                <div class="mp-support-item__icon"><i class="fas fa-hand-holding-heart"></i></div>
                <h4>Donate</h4>
                <p>Make a financial contribution — every dollar brings us closer to our goal</p>
                <a asp-action="Donate" asp-route-id="@Model.Id" class="btn btn-primary btn-sm">Give Now</a>
            </div>
            <div class="mp-support-item">
                <div class="mp-support-item__icon"><i class="fas fa-share-alt"></i></div>
                <h4>Share</h4>
                <p>Spread the word in your network and on social media</p>
            </div>
            <div class="mp-support-item">
                <div class="mp-support-item__icon"><i class="fas fa-hands"></i></div>
                <h4>Volunteer</h4>
                <p>Offer your time and skills to help with the project</p>
                <a asp-action="Contact" asp-controller="Home" class="btn btn-secondary btn-sm">Get in Touch</a>
            </div>
            <div class="mp-support-item">
                <div class="mp-support-item__icon"><i class="fas fa-pray"></i></div>
                <h4>Make Du'a</h4>
                <p>Ask Allah (SWT) to bless this project and all who support it</p>
            </div>
        </div>
    </div>
</section>

@* ─── Lightbox overlay ─────────────────────────────────────────────────────── *@
<div class="mp-lightbox" id="lightbox" onclick="closeLightbox()">
    <span class="mp-lightbox__close">&times;</span>
    <img id="lightboxImg" src="" alt="" />
</div>

@section Scripts {
<style>
/* ── Hero ──────────────────────────────────────────────────────────────────── */
.mp-hero {
    position: relative;
    min-height: 520px;
    display: flex;
    align-items: flex-end;
    padding-bottom: 60px;
    margin-top: 102px;
    overflow: hidden;
}
.mp-hero__bg {
    position: absolute; inset: 0;
    background-size: cover;
    background-position: center;
    transform: scale(1.05);
    transition: transform 8s ease;
}
.mp-hero:hover .mp-hero__bg { transform: scale(1); }
.mp-hero__overlay {
    position: absolute; inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,.85) 0%, rgba(0,0,0,.3) 60%, transparent 100%);
}
.mp-hero__content {
    position: relative;
    z-index: 2;
    color: #fff;
}
.mp-hero__badge {
    display: inline-block;
    background: var(--secondary-color);
    color: #000;
    padding: 4px 14px;
    border-radius: 20px;
    font-size: .8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 14px;
}
.mp-hero__title {
    font-size: clamp(1.8rem, 4vw, 3rem);
    line-height: 1.2;
    margin-bottom: 10px;
    text-shadow: 0 2px 8px rgba(0,0,0,.5);
}
.mp-hero__sub {
    font-size: 1.1rem;
    opacity: .9;
    margin-bottom: 24px;
}
.mp-hero__stats {
    display: flex;
    align-items: center;
    gap: 24px;
    margin-bottom: 16px;
    flex-wrap: wrap;
}
.mp-stat strong { display: block; font-size: 1.5rem; font-weight: 700; }
.mp-stat span   { font-size: .8rem; opacity: .8; text-transform: uppercase; letter-spacing: 1px; }
.mp-stat-divider { width: 1px; height: 36px; background: rgba(255,255,255,.4); }
.mp-hero__progress {
    height: 6px;
    background: rgba(255,255,255,.25);
    border-radius: 3px;
    margin-bottom: 24px;
    max-width: 500px;
}
.mp-hero__progress-bar {
    height: 100%;
    background: var(--secondary-color);
    border-radius: 3px;
    transition: width 1.2s ease;
}
.btn-gold {
    background: linear-gradient(135deg, var(--secondary-color), #b8941f);
    color: #000 !important;
    font-weight: 700;
    border-radius: 30px;
    padding: 14px 32px;
}
.btn-gold:hover { transform: translateY(-2px); box-shadow: 0 6px 20px rgba(0,0,0,.3); }

/* ── Body layout ───────────────────────────────────────────────────────────── */
.mp-body { padding: 60px 0; background: var(--light-bg); }
.mp-grid { display: grid; grid-template-columns: 1fr 340px; gap: 32px; align-items: start; }
@@media (max-width: 900px) { .mp-grid { grid-template-columns: 1fr; } }

/* ── Cards ─────────────────────────────────────────────────────────────────── */
.mp-card {
    background: #fff;
    border-radius: 12px;
    padding: 32px;
    box-shadow: 0 2px 12px rgba(0,0,0,.07);
    margin-bottom: 28px;
}
.mp-card__title {
    font-size: 1.3rem;
    color: var(--primary-color);
    margin-bottom: 6px;
    display: flex;
    align-items: center;
    gap: 10px;
}
.mp-card__sub { color: var(--text-light); font-size: .9rem; margin-bottom: 20px; }
.mp-overview__text { color: var(--text-light); line-height: 1.8; margin-bottom: 24px; }
.mp-details-row { display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 16px; }
.mp-detail {
    display: flex; gap: 12px; align-items: flex-start;
    padding: 14px; background: var(--light-bg); border-radius: 8px;
}
.mp-detail i { color: var(--secondary-color); font-size: 1.2rem; margin-top: 2px; }
.mp-detail h4 { font-size: .85rem; color: var(--text-light); margin-bottom: 2px; }
.mp-detail p  { font-size: .95rem; font-weight: 600; }

/* ── Gallery ───────────────────────────────────────────────────────────────── */
.mp-gallery {}
.mp-gallery__main {
    position: relative;
    border-radius: 10px;
    overflow: hidden;
    cursor: zoom-in;
    margin-bottom: 12px;
    background: #111;
    height: 340px;
}
.mp-gallery__main img {
    width: 100%; height: 100%;
    object-fit: cover;
    display: block;
    transition: transform .4s ease;
}
.mp-gallery__main:hover img { transform: scale(1.03); }
.mp-gallery__caption {
    position: absolute; bottom: 0; left: 0; right: 0;
    background: linear-gradient(transparent, rgba(0,0,0,.7));
    color: #fff; padding: 20px 16px 12px;
    font-size: .9rem;
}
.mp-gallery__thumbs {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 8px;
}
.mp-gallery__thumb {
    border-radius: 6px;
    overflow: hidden;
    cursor: pointer;
    opacity: .65;
    transition: opacity .2s, transform .2s;
    aspect-ratio: 1;
    border: 2px solid transparent;
}
.mp-gallery__thumb:hover,
.mp-gallery__thumb.active {
    opacity: 1;
    border-color: var(--secondary-color);
    transform: scale(1.05);
}
.mp-gallery__thumb img { width: 100%; height: 100%; object-fit: cover; display: block; }

/* ── Videos ────────────────────────────────────────────────────────────────── */
.mp-video-tabs { display: flex; gap: 8px; margin-bottom: 16px; flex-wrap: wrap; }
.mp-video-tab {
    padding: 8px 16px; border: 2px solid var(--border-color);
    border-radius: 20px; background: #fff; cursor: pointer;
    font-size: .85rem; font-weight: 600; color: var(--text-light);
    transition: all .2s;
}
.mp-video-tab.active,
.mp-video-tab:hover {
    background: var(--primary-color); color: #fff; border-color: var(--primary-color);
}
.mp-video-panel { display: none; }
.mp-video-panel.active { display: block; }
.mp-video-wrap {
    position: relative; padding-bottom: 56.25%;
    height: 0; overflow: hidden; border-radius: 10px;
    background: #000; margin-bottom: 12px;
}
.mp-video-wrap iframe {
    position: absolute; top: 0; left: 0;
    width: 100%; height: 100%; border: 0;
}
.mp-video-info h4 { font-size: 1rem; margin-bottom: 4px; }
.mp-video-info p  { color: var(--text-light); font-size: .9rem; }

/* ── Updates ───────────────────────────────────────────────────────────────── */
.mp-updates { border-left: 4px solid var(--secondary-color); }
.mp-update-body { display: flex; gap: 16px; align-items: flex-start; }
.mp-update-icon {
    flex-shrink: 0; width: 48px; height: 48px;
    background: var(--gradient-primary); border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    color: #fff; font-size: 1.2rem;
}
.mp-update-body p   { color: var(--text-light); line-height: 1.7; margin-bottom: 8px; }
.mp-update-body small { color: var(--text-light); font-size: .8rem; }

/* ── Features ──────────────────────────────────────────────────────────────── */
.mp-features {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
    gap: 20px;
    margin-top: 16px;
}
.mp-feature {
    text-align: center; padding: 24px 16px;
    border: 1px solid var(--border-color); border-radius: 10px;
    transition: transform .2s, box-shadow .2s;
}
.mp-feature:hover { transform: translateY(-4px); box-shadow: var(--shadow); }
.mp-feature__icon {
    width: 56px; height: 56px; border-radius: 50%;
    background: var(--gradient-primary);
    display: flex; align-items: center; justify-content: center;
    color: #fff; font-size: 1.3rem;
    margin: 0 auto 12px;
}
.mp-feature h4 { font-size: .95rem; margin-bottom: 6px; }
.mp-feature p  { font-size: .82rem; color: var(--text-light); }

/* ── Sidebar cards ─────────────────────────────────────────────────────────── */
.mp-sidebar { position: sticky; top: 90px; }
.mp-fund-card {
    background: #fff; border-radius: 14px;
    box-shadow: 0 4px 20px rgba(0,0,0,.1);
    overflow: hidden; margin-bottom: 20px;
}
.mp-fund-card__header {
    background: var(--gradient-primary);
    color: #fff; padding: 18px 24px;
}
.mp-fund-card__header h3 { font-size: 1.1rem; margin: 0; }
.mp-fund-card__body { padding: 24px; }
.mp-fund-amounts {
    display: flex; justify-content: space-between; align-items: baseline;
    margin-bottom: 10px;
}
.mp-fund-raised { font-size: 2rem; font-weight: 700; color: var(--primary-color); }
.mp-fund-label  { color: var(--text-light); font-size: .85rem; margin-left: 4px; }
.mp-fund-pct    { font-size: 1.4rem; font-weight: 700; color: var(--secondary-color); }
.mp-fund-bar {
    height: 10px; background: var(--border-color);
    border-radius: 5px; margin-bottom: 6px; overflow: hidden;
}
.mp-fund-bar__fill {
    height: 100%; background: linear-gradient(to right, var(--primary-color), var(--secondary-color));
    border-radius: 5px; transition: width 1.2s ease;
}
.mp-fund-goal { font-size: .85rem; color: var(--text-light); margin-bottom: 16px; }
.mp-fund-meta { display: flex; gap: 16px; margin-bottom: 8px; }
.mp-fund-meta__item {
    flex: 1; text-align: center; padding: 10px;
    background: var(--light-bg); border-radius: 8px;
}
.mp-fund-meta__item i { color: var(--secondary-color); display: block; margin-bottom: 4px; }
.mp-fund-meta__item strong { display: block; font-size: 1.1rem; }
.mp-fund-meta__item span  { font-size: .75rem; color: var(--text-light); }
.mp-fund-secure { text-align: center; font-size: .78rem; color: var(--text-light); margin-top: 10px; }
.mp-fund-secure i { color: var(--success-color); }
.btn-block { display: block; width: 100%; text-align: center; }
.mt-2 { margin-top: 12px; }

.mp-impact-card {
    background: #fff; border-radius: 12px; padding: 20px 24px;
    box-shadow: 0 2px 10px rgba(0,0,0,.07); margin-bottom: 20px;
}
.mp-impact-card h4 { color: var(--primary-color); margin-bottom: 14px; font-size: 1rem; }
.mp-impact-list { list-style: none; padding: 0; margin: 0; }
.mp-impact-list li {
    display: flex; align-items: center; gap: 12px;
    padding: 10px 0; border-bottom: 1px solid var(--border-color);
    font-size: .9rem;
}
.mp-impact-list li:last-child { border-bottom: none; }
.mp-impact-amt {
    flex-shrink: 0; min-width: 56px;
    background: var(--gradient-primary); color: #fff;
    padding: 4px 10px; border-radius: 12px; font-size: .8rem; font-weight: 700;
}

.mp-share-card {
    background: #fff; border-radius: 12px; padding: 20px 24px;
    box-shadow: 0 2px 10px rgba(0,0,0,.07);
}
.mp-share-card h4 { color: var(--primary-color); margin-bottom: 6px; font-size: 1rem; }
.mp-share-card p  { color: var(--text-light); font-size: .85rem; margin-bottom: 14px; }
.mp-share-btns { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; }
.mp-share-btn {
    display: flex; align-items: center; justify-content: center; gap: 7px;
    padding: 9px 12px; border-radius: 8px; font-size: .82rem; font-weight: 600;
    text-decoration: none; cursor: pointer; border: none; transition: all .2s;
}
.mp-share-btn--fb { background: #1877f2; color: #fff; }
.mp-share-btn--wa { background: #25d366; color: #fff; }
.mp-share-btn--tw { background: #1da1f2; color: #fff; }
.mp-share-btn--copy { background: var(--light-bg); color: var(--text-dark); border: 1px solid var(--border-color); }
.mp-share-btn:hover { opacity: .88; transform: translateY(-1px); }

/* ── Hadith ────────────────────────────────────────────────────────────────── */
.mp-hadith {
    background: var(--gradient-primary);
    padding: 60px 0;
    text-align: center;
    color: #fff;
}
.mp-hadith__inner { max-width: 720px; margin: 0 auto; }
.mp-hadith__icon { font-size: 3rem; opacity: .4; margin-bottom: 16px; display: block; }
.mp-hadith blockquote {
    font-family: 'Amiri', serif;
    font-size: clamp(1.1rem, 2.5vw, 1.5rem);
    line-height: 1.7;
    border: none; padding: 0; margin: 0;
}
.mp-hadith cite { display: block; margin-top: 14px; font-size: .9rem; opacity: .75; font-style: normal; }

/* ── Support section ───────────────────────────────────────────────────────── */
.mp-support { padding: 70px 0; background: var(--light-bg); }
.mp-support__title { text-align: center; font-size: 2rem; color: var(--primary-color); margin-bottom: 40px; }
.mp-support-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(210px, 1fr));
    gap: 24px;
}
.mp-support-item {
    background: #fff; border-radius: 12px; padding: 32px 24px;
    text-align: center; box-shadow: 0 2px 10px rgba(0,0,0,.07);
    transition: transform .2s, box-shadow .2s;
}
.mp-support-item:hover { transform: translateY(-5px); box-shadow: 0 8px 25px rgba(0,0,0,.12); }
.mp-support-item__icon {
    width: 64px; height: 64px; border-radius: 50%;
    background: var(--gradient-secondary);
    display: flex; align-items: center; justify-content: center;
    font-size: 1.5rem; color: #fff; margin: 0 auto 16px;
}
.mp-support-item h4 { font-size: 1.1rem; margin-bottom: 8px; }
.mp-support-item p  { color: var(--text-light); font-size: .9rem; margin-bottom: 16px; }
.btn-sm { padding: 8px 20px; font-size: .85rem; }

/* ── Lightbox ──────────────────────────────────────────────────────────────── */
.mp-lightbox {
    display: none; position: fixed; inset: 0; z-index: 9999;
    background: rgba(0,0,0,.92); align-items: center; justify-content: center;
}
.mp-lightbox.open { display: flex; }
.mp-lightbox img { max-width: 90vw; max-height: 90vh; border-radius: 8px; }
.mp-lightbox__close {
    position: absolute; top: 20px; right: 30px;
    font-size: 2.5rem; color: #fff; cursor: pointer; line-height: 1;
}
</style>

<script>
// Gallery
function setGalleryImg(thumb, src, caption) {
    document.querySelectorAll('.mp-gallery__thumb').forEach(t => t.classList.remove('active'));
    thumb.classList.add('active');
    const img = document.getElementById('galleryMainImg');
    img.style.opacity = '0';
    setTimeout(() => {
        img.src = src;
        img.onerror = () => img.src = '/images/masjid-project.jpg';
        img.style.opacity = '1';
    }, 150);
    document.getElementById('galleryCaption').textContent = caption;
}

// Lightbox on main image click
document.getElementById('galleryMain').addEventListener('click', function () {
    const lb = document.getElementById('lightbox');
    document.getElementById('lightboxImg').src = document.getElementById('galleryMainImg').src;
    lb.classList.add('open');
});
function closeLightbox() {
    document.getElementById('lightbox').classList.remove('open');
}

// Video tabs
function switchVideo(btn, panelId) {
    document.querySelectorAll('.mp-video-tab').forEach(b => b.classList.remove('active'));
    document.querySelectorAll('.mp-video-panel').forEach(p => p.classList.remove('active'));
    btn.classList.add('active');
    document.getElementById(panelId).classList.add('active');
}

// Share — copy link
function copyLink() {
    navigator.clipboard.writeText(window.location.href).then(() => {
        const btn = document.querySelector('.mp-share-btn--copy');
        btn.innerHTML = '<i class="fas fa-check"></i> Copied!';
        setTimeout(() => { btn.innerHTML = '<i class="fas fa-link"></i> Copy Link'; }, 2000);
    });
}
</script>
}
