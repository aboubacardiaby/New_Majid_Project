@* ═══════════════════════════════════════════════════════════════════════════
   4. MASJID PROJECT HIGHLIGHT
   ═══════════════════════════════════════════════════════════════════════════ *@
@if (Model.FeaturedMasjidProject != null)
{
    var pct = Math.Min((double)Model.FeaturedMasjidProject.ProgressPercentage, 100);
    <section class="ih-project">
        <div class="container">
            <div class="ih-project__inner">
                <div class="ih-project__left">
                    <div class="ih-project__badge"><i class="fas fa-mosque"></i> Featured Project</div>
                    <h2 class="ih-project__title">@Model.FeaturedMasjidProject.Title</h2>
                    <p class="ih-project__desc">
                        @(Model.FeaturedMasjidProject.Description.Length > 280
                            ? Model.FeaturedMasjidProject.Description.Substring(0, 280) + "…"
                            : Model.FeaturedMasjidProject.Description)
                    </p>
                    <div class="ih-project__stats">
                        <div class="ih-project__stat">
                            <strong>$@Model.FeaturedMasjidProject.TargetAmount.ToString("N0")</strong>
                            <span>Goal</span>
                        </div>
                        <div class="ih-project__stat">
                            <strong>$@Model.FeaturedMasjidProject.CurrentAmount.ToString("N0")</strong>
                            <span>Raised</span>
                        </div>
                        <div class="ih-project__stat">
                            <strong>@Model.FeaturedMasjidProject.ProgressPercentage%</strong>
                            <span>Funded</span>
                        </div>
                        <div class="ih-project__stat">
                            <strong>@Model.FeaturedMasjidProject.DaysRemaining</strong>
                            <span>Days Left</span>
                        </div>
                    </div>
                    <div class="ih-project__bar-wrap">
                        <div class="ih-project__bar-fill" style="width:@pct%"></div>
                    </div>
                    <p class="ih-project__bar-label">@pct% of goal reached — Status: @Model.FeaturedMasjidProject.Status</p>
                    <div class="ih-project__btns">
                        <a asp-action="Donate" asp-route-id="@Model.FeaturedMasjidProject.Id" class="ih-btn-gold">
                            <i class="fas fa-heart"></i> Donate Now
                        </a>
                        <a asp-action="MasjidProject" asp-route-id="@Model.FeaturedMasjidProject.Id" class="ih-btn-outline">
                            <i class="fas fa-info-circle"></i> Learn More
                        </a>
                    </div>
                </div>
                <div class="ih-project__card">
                    <h4><i class="fas fa-hand-holding-heart"></i> Your Donation Impact</h4>
                    <ul class="ih-project__impact">
                        <li><span class="amt">$50</span> Sponsor prayer rugs</li>
                        <li><span class="amt">$100</span> Classroom equipment</li>
                        <li><span class="amt">$250</span> Sound system contribution</li>
                        <li><span class="amt">$500</span> Construction materials</li>
                        <li><span class="amt">$1,000</span> Sponsor a building section</li>
                    </ul>
                    <a asp-action="MasjidProject" asp-route-id="@Model.FeaturedMasjidProject.Id" class="ih-btn-gold" style="justify-content:center;width:100%;display:flex;">
                        <i class="fas fa-mosque"></i> View Full Project
                    </a>
                </div>
            </div>
        </div>
    </section>
}

@* ═══════════════════════════════════════════════════════════════════════════
   5. ABOUT
   ═══════════════════════════════════════════════════════════════════════════ *@
<section class="ih-about">
    <div class="container">
        <div class="ih-about__grid">
            <div class="ih-about__art">
                <div class="ih-about__hex-wrap">
                    <div class="ih-hex-ring"></div>
                    <div class="ih-hex-ring2"></div>
                    <div class="ih-hex-center"><i class="fas fa-mosque"></i></div>
                    <div class="ih-hex-dot" style="top:10px;left:50%;transform:translateX(-50%)"></div>
                    <div class="ih-hex-dot" style="bottom:10px;left:50%;transform:translateX(-50%)"></div>
                    <div class="ih-hex-dot" style="left:10px;top:50%;transform:translateY(-50%)"></div>
                    <div class="ih-hex-dot" style="right:10px;top:50%;transform:translateY(-50%)"></div>
                </div>
            </div>
            <div>
                <div class="ih-section-label">Who we are</div>
                <h2 class="ih-section-title">About Our Community</h2>
                <p style="color:var(--text-light);line-height:1.8;margin-bottom:8px;">
                    The Gambian Muslim Community in Minnesota is dedicated to preserving our Islamic faith and Gambian cultural heritage while integrating into the broader Minnesota community.
                </p>
                <p style="color:var(--text-light);line-height:1.8;margin-bottom:20px;">
                    We strive to provide spiritual guidance, educational opportunities, and social support for Gambian Muslims and their families.
                </p>
                <ul class="ih-about__value-list">
                    <li><div class="ih-about__val-icon"><i class="fas fa-heart"></i></div> Faith &amp; Spirituality</li>
                    <li><div class="ih-about__val-icon"><i class="fas fa-users"></i></div> Community Unity</li>
                    <li><div class="ih-about__val-icon"><i class="fas fa-graduation-cap"></i></div> Education &amp; Learning</li>
                    <li><div class="ih-about__val-icon"><i class="fas fa-hands-helping"></i></div> Service to Others</li>
                    <li><div class="ih-about__val-icon"><i class="fas fa-globe-americas"></i></div> Cultural Preservation</li>
                </ul>
                <a asp-action="About" class="btn btn-primary" style="margin-top:20px;">
                    <i class="fas fa-arrow-right"></i> Learn More About Us
                </a>
            </div>
        </div>
    </div>
</section>

@* ═══════════════════════════════════════════════════════════════════════════
   6. SERVICES
   ═══════════════════════════════════════════════════════════════════════════ *@
<section class="ih-services">
    <div class="container">
        <div style="text-align:center">
            <div class="ih-section-label">What we offer</div>
            <h2 class="ih-section-title">Our Services</h2>
            <p class="ih-section-sub">Serving the spiritual, educational, and social needs of our community</p>
        </div>
        <div class="ih-divider"><i class="fas fa-star"></i></div>
        <div class="ih-services__grid">
            @foreach (var service in Model.Services)
            {
                <div class="ih-service-card">
                    <div class="ih-service-icon"><i class="@service.IconClass"></i></div>
                    <h3>@service.Title</h3>
                    <p>@service.Description</p>
                    <div class="ih-service-card__corner"><i class="fas fa-mosque"></i></div>
                </div>
            }
        </div>
    </div>
</section>

@* ═══════════════════════════════════════════════════════════════════════════
   7. EVENTS
   ═══════════════════════════════════════════════════════════════════════════ *@
<section class="ih-events">
    <div class="container">
        <div style="text-align:center">
            <div class="ih-section-label">Join us</div>
            <h2 class="ih-section-title">Upcoming Events</h2>
            <p class="ih-section-sub">Strengthen your faith and community bonds at our upcoming gatherings</p>
        </div>
        <div class="ih-divider"><i class="fas fa-star"></i></div>
        <div class="ih-events__grid">
            @foreach (var ev in Model.UpcomingEvents)
            {
                <div class="ih-event-card">
                    <div class="ih-event-date">
                        <span class="ih-event-month">@ev.EventDate.ToString("MMM")</span>
                        <span class="ih-event-day">@ev.EventDate.Day</span>
                        <span class="ih-event-year">@ev.EventDate.Year</span>
                    </div>
                    <div class="ih-event-body">
                        <span class="ih-event-type">@ev.EventType</span>
                        <h3>@ev.Title</h3>
                        <div class="ih-event-meta">
                            <span><i class="fas fa-clock"></i> @(DateTime.Today.Add(ev.StartTime).ToString("h:mm tt")) – @(DateTime.Today.Add(ev.EndTime).ToString("h:mm tt"))</span>
                            <span><i class="fas fa-map-marker-alt"></i> @ev.Location</span>
                        </div>
                    </div>
                </div>
            }
        </div>
        <div class="ih-events__cta">
            <a asp-action="Events" class="btn btn-primary"><i class="fas fa-calendar-alt"></i> View All Events</a>
        </div>
    </div>
</section>

@* ═══════════════════════════════════════════════════════════════════════════
   8. PRAYER TIMES
   ═══════════════════════════════════════════════════════════════════════════ *@
<section class="ih-prayer">
    <div class="container">
        <div class="ih-prayer__heading" style="text-align:center;margin-bottom:40px;">
            <div class="ih-prayer__city"><i class="fas fa-map-marker-alt"></i> @Model.PrayerSchedule.City</div>
            <h2 class="ih-prayer__title">Prayer Times</h2>
        </div>
        <div class="ih-prayer__grid">
            @{
                var prayerIcons = new Dictionary<string, string> {
                    {"Fajr","fas fa-star"},{"Dhuhr","fas fa-sun"},
                    {"Asr","fas fa-cloud-sun"},{"Maghrib","fas fa-moon"},{"Isha","fas fa-star-and-crescent"}
                };
            }
            @foreach (var prayer in Model.PrayerSchedule.Prayers)
            {
                var icon = prayerIcons.TryGetValue(prayer.Name, out var ic) ? ic : "fas fa-clock";
                <div class="ih-prayer-card @(prayer.IsNext ? "next-prayer" : "")">
                    <div class="ih-prayer-next-badge">Next</div>
                    <div class="ih-prayer-card__icon"><i class="@icon"></i></div>
                    <h3>@prayer.Name</h3>
                    <div class="time">@(DateTime.Today.Add(prayer.Time).ToString("h:mm tt"))</div>
                </div>
            }
        </div>
        <p class="ih-prayer__note">
            <i class="fas fa-info-circle"></i>
            Times are approximate for @Model.PrayerSchedule.City. Please verify with local mosque for exact times.
        </p>
    </div>
    <div class="ih-prayer__mosque">
        <svg viewBox="0 0 1440 100" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
            <rect x="60" y="20" width="14" height="80" fill="#d4af37"/>
            <polygon points="67,5 60,28 74,28" fill="#d4af37"/>
            <rect x="1366" y="20" width="14" height="80" fill="#d4af37"/>
            <polygon points="1373,5 1366,28 1380,28" fill="#d4af37"/>
            <ellipse cx="720" cy="35" rx="110" ry="40" fill="#d4af37"/>
            <rect x="610" y="35" width="220" height="65" fill="#d4af37"/>
            <ellipse cx="430" cy="58" rx="60" ry="30" fill="#d4af37"/>
            <rect x="370" y="58" width="120" height="42" fill="#d4af37"/>
            <ellipse cx="1010" cy="58" rx="60" ry="30" fill="#d4af37"/>
            <rect x="950" y="58" width="120" height="42" fill="#d4af37"/>
        </svg>
    </div>
</section>

@* ═══════════════════════════════════════════════════════════════════════════
   9. JOIN CTA
   ═══════════════════════════════════════════════════════════════════════════ *@
<section class="ih-cta">
    <div class="container">
        <div class="ih-cta__inner">
            <div class="ih-cta__icon"><i class="fas fa-mosque"></i></div>
            <h2>Join Our Community</h2>
            <p>Register as a member, connect with brothers and sisters, and grow together in faith</p>
            <div class="ih-cta__btns">
                <a asp-action="Register" asp-controller="Membership" class="ih-btn-dark">
                    <i class="fas fa-user-plus"></i> Become a Member
                </a>
                <a asp-action="Contact" asp-controller="Home" class="ih-btn-white">
                    <i class="fas fa-envelope"></i> Contact Us
                </a>
            </div>
        </div>
    </div>
</section>

@section Scripts {
<script>
// Generate twinkling stars in hero
(function () {
    var wrap = document.getElementById('heroStars');
    if (!wrap) return;
    for (var i = 0; i < 80; i++) {
        var s = document.createElement('div');
        s.className = 'ih-star';
        s.style.cssText = [
            'left:' + Math.random() * 100 + '%',
            'top:'  + Math.random() * 70 + '%',
            '--d:'  + (2 + Math.random() * 4) + 's',
            '--delay:' + (Math.random() * 5) + 's',
            '--op:' + (0.4 + Math.random() * 0.6),
            'width:' + (1 + Math.random() * 2.5) + 'px',
            'height:' + (1 + Math.random() * 2.5) + 'px'
        ].join(';');
        wrap.appendChild(s);
    }
})();
</script>
}
