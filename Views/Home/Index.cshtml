    @* Mosque silhouette SVG *@
    <div class="ih-hero__mosque">
        <svg viewBox="0 0 1440 180" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
            <defs>
                <linearGradient id="mgGrad" x1="0" y1="0" x2="0" y2="1">
                    <stop offset="0%" stop-color="rgba(212,175,55,0.08)"/>
                    <stop offset="100%" stop-color="rgba(212,175,55,0.25)"/>
                </linearGradient>
            </defs>
            <!-- Minaret left -->
            <rect x="60" y="40" width="18" height="140" fill="url(#mgGrad)"/>
            <polygon points="69,20 60,50 78,50" fill="url(#mgGrad)"/>
            <rect x="65" y="30" width="8" height="14" fill="url(#mgGrad)"/>
            <!-- Minaret right -->
            <rect x="1362" y="40" width="18" height="140" fill="url(#mgGrad)"/>
            <polygon points="1371,20 1362,50 1380,50" fill="url(#mgGrad)"/>
            <rect x="1367" y="30" width="8" height="14" fill="url(#mgGrad)"/>
            <!-- Main dome -->
            <ellipse cx="720" cy="60" rx="160" ry="60" fill="url(#mgGrad)"/>
            <rect x="560" y="60" width="320" height="120" fill="url(#mgGrad)"/>
            <!-- Small domes -->
            <ellipse cx="440" cy="100" rx="70" ry="40" fill="url(#mgGrad)"/>
            <rect x="370" y="100" width="140" height="80" fill="url(#mgGrad)"/>
            <ellipse cx="1000" cy="100" rx="70" ry="40" fill="url(#mgGrad)"/>
            <rect x="930" y="100" width="140" height="80" fill="url(#mgGrad)"/>
            <!-- Ground -->
