@* ═══════════════════════════════════════════════════════════════════════════
   3. IMAM WELCOME
   ═══════════════════════════════════════════════════════════════════════════ *@
<section class="ih-imam">
    <div class="container">
        <div class="ih-imam__card">
            <div class="ih-imam__left">
                <div class="ih-imam__photo-wrap">
                    <div class="ih-imam__photo-ring">
                        <img src="@Model.ImamWelcome.ImamImageUrl"
                             alt="@Model.ImamWelcome.ImamName"
                             onerror="this.src='/images/imam-placeholder.jpg'" />
