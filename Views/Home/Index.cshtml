                    <i class="fas fa-quote-right ih-imam__quote-icon"></i>
                    <p class="ih-imam__quote-text">@Model.ImamWelcome.WelcomeMessage</p>
                </div>
                <div class="ih-imam__sig">
                    <div class="ih-imam__sig-line"></div>
                    <span class="ih-imam__sig-name">@Model.ImamWelcome.ImamName</span>
