@model ManualContribution
@{
    ViewData["Title"] = "Add Manual Contribution";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="row">
    <div class="col-12">
        <div class="card">
            <div class="card-header">
                <h5 class="mb-0">
                    <i class="fas fa-plus-circle me-2"></i>
                    Add Manual Contribution
                </h5>
            </div>
            <div class="card-body">
                @if (TempData["SuccessMessage"] != null)
                {
                    <div class="alert alert-success alert-dismissible fade show" role="alert">
                        <i class="fas fa-check-circle me-2"></i>
                        @TempData["SuccessMessage"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                }

                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="alert alert-danger">
                        <h6><i class="fas fa-exclamation-triangle me-2"></i>Please correct the following errors:</h6>
                        <ul class="mb-0">
                            @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                            {
                                <li>@error.ErrorMessage</li>
                            }
                        </ul>
                    </div>
                }

                <form asp-action="AddContribution" method="post">
                    @Html.AntiForgeryToken()
                    
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label asp-for="ContributorName" class="form-label required">
                                    <i class="fas fa-user me-1"></i>
                                    @Html.DisplayNameFor(m => m.ContributorName)
                                </label>
                                <input asp-for="ContributorName" class="form-control" placeholder="Enter contributor's full name" />
                                <span asp-validation-for="ContributorName" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label asp-for="Email" class="form-label required">
                                    <i class="fas fa-envelope me-1"></i>
                                    @Html.DisplayNameFor(m => m.Email)
                                </label>
                                <input asp-for="Email" type="email" class="form-control" placeholder="contributor@example.com" />
                                <span asp-validation-for="Email" class="text-danger"></span>
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-4">
                            <div class="form-group mb-3">
                                <label asp-for="Amount" class="form-label required">
                                    <i class="fas fa-dollar-sign me-1"></i>
                                    @Html.DisplayNameFor(m => m.Amount)
                                </label>
                                <div class="input-group">
                                    <span class="input-group-text">$</span>
                                    <input asp-for="Amount" type="number" step="0.01" min="0.01" class="form-control" placeholder="0.00" />
                                </div>
                                <span asp-validation-for="Amount" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-group mb-3">
                                <label asp-for="ProjectName" class="form-label required">
                                    <i class="fas fa-project-diagram me-1"></i>
                                    @Html.DisplayNameFor(m => m.ProjectName)
                                </label>
                                <select asp-for="ProjectName" class="form-select">
                                    <option value="">-- Select Project --</option>
                                    @if (Model.AvailableProjects != null)
                                    {
                                        @foreach (var project in Model.AvailableProjects)
                                        {
                                            <option value="@project">@project</option>
                                        }
                                    }
                                </select>
                                <span asp-validation-for="ProjectName" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-group mb-3">
                                <label asp-for="PaymentMethod" class="form-label required">
                                    <i class="fas fa-credit-card me-1"></i>
                                    @Html.DisplayNameFor(m => m.PaymentMethod)
                                </label>
                                <select asp-for="PaymentMethod" class="form-select">
                                    <option value="">-- Select Payment Method --</option>
                                    @if (Model.PaymentMethods != null)
                                    {
                                        @foreach (var method in Model.PaymentMethods)
                                        {
                                            <option value="@method">@method</option>
                                        }
                                    }
                                </select>
                                <span asp-validation-for="PaymentMethod" class="text-danger"></span>
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label asp-for="ContributionDate" class="form-label">
                                    <i class="fas fa-calendar me-1"></i>
                                    @Html.DisplayNameFor(m => m.ContributionDate)
                                </label>
                                <input asp-for="ContributionDate" type="datetime-local" class="form-control" />
                                <span asp-validation-for="ContributionDate" class="text-danger"></span>
                                <div class="form-text">Leave blank to use current date and time</div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label asp-for="Notes" class="form-label">
                                    <i class="fas fa-sticky-note me-1"></i>
                                    @Html.DisplayNameFor(m => m.Notes)
                                </label>
                                <textarea asp-for="Notes" class="form-control" rows="3" placeholder="Optional notes about this contribution"></textarea>
                                <span asp-validation-for="Notes" class="text-danger"></span>
                            </div>
                        </div>
                    </div>

                    <div class="form-actions">
                        <button type="submit" class="btn btn-success me-2">
                            <i class="fas fa-save me-1"></i>
                            Add Contribution
                        </button>
                        <a asp-action="Admin" class="btn btn-secondary">
                            <i class="fas fa-arrow-left me-1"></i>
                            Back to Admin
                        </a>
                    </div>
                </form>
            </div>
        </div>

        <!-- Info Panel -->
        <div class="card mt-4">
            <div class="card-header">
                <h6 class="mb-0">
                    <i class="fas fa-info-circle me-2"></i>
                    Important Information
                </h6>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-6">
                        <h6><i class="fas fa-check-circle text-success me-2"></i>What happens when you add a contribution:</h6>
                        <ul class="list-unstyled">
                            <li><i class="fas fa-chevron-right text-primary me-2"></i>A donation record is created in the system</li>
                            <li><i class="fas fa-chevron-right text-primary me-2"></i>The contribution tracker is automatically updated</li>
                            <li><i class="fas fa-chevron-right text-primary me-2"></i>Analytics and reports will reflect the new contribution</li>
                            <li><i class="fas fa-chevron-right text-primary me-2"></i>The contributor can view it in their personal report</li>
                        </ul>
                    </div>
                    <div class="col-md-6">
                        <h6><i class="fas fa-exclamation-triangle text-warning me-2"></i>Please note:</h6>
                        <ul class="list-unstyled">
                            <li><i class="fas fa-chevron-right text-warning me-2"></i>Ensure the email address is correct for proper tracking</li>
                            <li><i class="fas fa-chevron-right text-warning me-2"></i>Double-check the amount before submitting</li>
                            <li><i class="fas fa-chevron-right text-warning me-2"></i>This action cannot be easily undone</li>
                            <li><i class="fas fa-chevron-right text-warning me-2"></i>Manual contributions are marked with a special transaction ID</li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
.required::after {
    content: " *";
    color: #dc3545;
}

.form-actions {
    padding-top: 20px;
    border-top: 1px solid #e9ecef;
    margin-top: 20px;
}

.card {
    box-shadow: 0 0.125rem 0.25rem rgba(0, 0, 0, 0.075);
    border: 1px solid rgba(0, 0, 0, 0.125);
}

.card-header {
    background-color: #f8f9fa;
    border-bottom: 1px solid rgba(0, 0, 0, 0.125);
}

.input-group-text {
    background-color: #e9ecef;
    border-color: #ced4da;
}

.btn-success {
    background-color: #198754;
    border-color: #198754;
}

.btn-success:hover {
    background-color: #157347;
    border-color: #146c43;
}
</style>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    
    <script>
        $(document).ready(function() {
            // Auto-format amount input
            $('input[name="Amount"]').on('blur', function() {
                var value = parseFloat($(this).val());
                if (!isNaN(value)) {
                    $(this).val(value.toFixed(2));
                }
            });

            // Set default date to now if empty
            var dateInput = $('input[name="ContributionDate"]');
            if (!dateInput.val()) {
                var now = new Date();
                var localDateTime = new Date(now.getTime() - now.getTimezoneOffset() * 60000).toISOString().slice(0, 16);
                dateInput.val(localDateTime);
            }
        });
    </script>
}