@model AdminProjectManagementViewModel

@{
    var project = Model.EditingProject;
}

<div class="row">
    <div class="col-md-8">
        <div class="card">
            <div class="card-header">
                <h6 class="mb-0">Project Information</h6>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-6">
                        <p><strong>Title:</strong> @project.Title</p>
                        <p><strong>Status:</strong> 
                            <span class="badge @(project.Status switch {
                                "Planning" => "bg-secondary",
                                "Fundraising" => "bg-info", 
                                "Construction" => "bg-warning",
                                "Completed" => "bg-success",
                                _ => "bg-secondary"
                            })">
                                @project.Status
                            </span>
                        </p>
                        <p><strong>Location:</strong> @(!string.IsNullOrEmpty(project.Location) ? project.Location : "Not specified")</p>
                        <p><strong>Start Date:</strong> @project.StartDate.ToString("MMMM dd, yyyy")</p>
                        @if (project.TargetCompletionDate.HasValue)
                        {
                            <p><strong>Target Completion:</strong> @project.TargetCompletionDate.Value.ToString("MMMM dd, yyyy")</p>
                            @if (project.DaysRemaining > 0)
                            {
                                <p><strong>Days Remaining:</strong> @project.DaysRemaining days</p>
                            }
                        }
                    </div>
                    <div class="col-md-6">
                        <p><strong>Target Amount:</strong> $@project.TargetAmount.ToString("N2")</p>
                        <p><strong>Current Amount:</strong> $@project.CurrentAmount.ToString("N2")</p>
                        <p><strong>Progress:</strong> @project.ProgressPercentage%</p>
                        <div class="progress mb-3" style="height: 25px;">
                            <div class="progress-bar @(project.ProgressPercentage >= 100 ? "bg-success" : project.ProgressPercentage >= 75 ? "bg-info" : project.ProgressPercentage >= 50 ? "bg-warning" : "bg-danger")" 
                                 role="progressbar" 
                                 style="width: @Math.Min(project.ProgressPercentage, 100)%"
                                 aria-valuenow="@project.ProgressPercentage" 
                                 aria-valuemin="0" 
                                 aria-valuemax="100">
                                @project.ProgressPercentage%
                            </div>
                        </div>
                        <p><strong>Featured:</strong> @(project.IsFeatured ? "Yes" : "No")</p>
                        <p><strong>Active:</strong> @(project.IsActive ? "Yes" : "No")</p>
                    </div>
                </div>
                
                @if (!string.IsNullOrEmpty(project.Description))
                {
                    <div class="mt-3">
                        <strong>Description:</strong>
                        <p class="mt-2">@project.Description</p>
                    </div>
                }
                
                @if (!string.IsNullOrEmpty(project.Updates))
                {
                    <div class="mt-3">
                        <strong>Updates:</strong>
                        <p class="mt-2">@project.Updates</p>
                    </div>
                }
                
                @if (!string.IsNullOrEmpty(project.ImageUrl))
                {
                    <div class="mt-3">
                        <strong>Project Image:</strong>
                        <div class="mt-2">
                            <img src="@project.ImageUrl" alt="@project.Title" class="img-thumbnail" style="max-width: 300px;" />
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
    
    <div class="col-md-4">
        <div class="card">
            <div class="card-header">
                <h6 class="mb-0">
                    <i class="fas fa-chart-bar me-2"></i>
                    Donation Statistics
                </h6>
            </div>
            <div class="card-body">
                <div class="text-center mb-3">
                    <h5 class="text-success">$@Model.TotalRaised.ToString("N2")</h5>
                    <small class="text-muted">Total Raised</small>
                </div>
                
                <hr>
                
                <div class="d-flex justify-content-between mb-2">
                    <span>Total Donations:</span>
                    <strong>@Model.ProjectDonations.Count</strong>
                </div>
                <div class="d-flex justify-content-between mb-2">
                    <span>Unique Donors:</span>
                    <strong>@Model.TotalDonators</strong>
                </div>
                <div class="d-flex justify-content-between mb-2">
                    <span>Average Donation:</span>
                    <strong>$@(Model.ProjectDonations.Any() ? (Model.ProjectDonations.Sum(d => d.Amount) / Model.ProjectDonations.Count).ToString("N2") : "0.00")</strong>
                </div>
                
                @if (Model.ProjectDonations.Any())
                {
                    <hr>
                    <div class="d-flex justify-content-between mb-2">
                        <span>Largest Donation:</span>
                        <strong>$@Model.ProjectDonations.Max(d => d.Amount).ToString("N2")</strong>
                    </div>
                    <div class="d-flex justify-content-between">
                        <span>Most Recent:</span>
                        <strong>@Model.ProjectDonations.OrderByDescending(d => d.DonationDate).First().DonationDate.ToString("MMM dd")</strong>
                    </div>
                }
            </div>
        </div>
        
        @if (Model.ProjectDonations.Any())
        {
            <div class="card mt-3">
                <div class="card-header">
                    <h6 class="mb-0">
                        <i class="fas fa-list me-2"></i>
                        Recent Donations
                    </h6>
                </div>
                <div class="card-body p-0">
                    <div class="list-group list-group-flush">
                        @foreach (var donation in Model.ProjectDonations.OrderByDescending(d => d.DonationDate).Take(5))
                        {
                            <div class="list-group-item">
                                <div class="d-flex w-100 justify-content-between">
                                    <h6 class="mb-1">@(donation.IsAnonymous ? "Anonymous" : donation.DonorName)</h6>
                                    <small class="text-success font-weight-bold">$@donation.Amount.ToString("N2")</small>
                                </div>
                                <p class="mb-1">
                                    <small class="text-muted">
                                        @donation.DonationDate.ToString("MMM dd, yyyy 'at' h:mm tt")
                                        @if (!string.IsNullOrEmpty(donation.PaymentMethod))
                                        {
                                            <text> via @donation.PaymentMethod</text>
                                        }
                                    </small>
                                </p>
                                @if (!string.IsNullOrEmpty(donation.Message))
                                {
                                    <small class="text-muted">@donation.Message</small>
                                }
                            </div>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
</div>