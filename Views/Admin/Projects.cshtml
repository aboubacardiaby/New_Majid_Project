@model AdminProjectManagementViewModel
@{
    ViewData["Title"] = "Project Management";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="row">
    <div class="col-12">
        <!-- Summary Cards -->
        <div class="row mb-4">
            <div class="col-md-3">
                <div class="card bg-primary text-white">
                    <div class="card-body">
                        <div class="d-flex justify-content-between">
                            <div>
                                <h6 class="card-title mb-0">Total Projects</h6>
                                <h2 class="mb-0">@Model.Projects.Count</h2>
                            </div>
                            <div class="align-self-center">
                                <i class="fas fa-project-diagram fa-2x opacity-75"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card bg-success text-white">
                    <div class="card-body">
                        <div class="d-flex justify-content-between">
                            <div>
                                <h6 class="card-title mb-0">Active Projects</h6>
                                <h2 class="mb-0">@Model.Projects.Count(p => p.IsActive)</h2>
                            </div>
                            <div class="align-self-center">
                                <i class="fas fa-play-circle fa-2x opacity-75"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card bg-info text-white">
                    <div class="card-body">
                        <div class="d-flex justify-content-between">
                            <div>
                                <h6 class="card-title mb-0">Total Raised</h6>
                                <h2 class="mb-0">$@Model.TotalRaised.ToString("N2")</h2>
                            </div>
                            <div class="align-self-center">
                                <i class="fas fa-dollar-sign fa-2x opacity-75"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card bg-warning text-white">
                    <div class="card-body">
                        <div class="d-flex justify-content-between">
                            <div>
                                <h6 class="card-title mb-0">Featured Project</h6>
                                <h2 class="mb-0">@(Model.Projects.Any(p => p.IsFeatured) ? "1" : "0")</h2>
                            </div>
                            <div class="align-self-center">
                                <i class="fas fa-star fa-2x opacity-75"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Projects Management Section -->
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5 class="mb-0">
                    <i class="fas fa-project-diagram me-2"></i>
                    Masjid Projects
                </h5>
                <a href="@Url.Action("CreateProject")" class="btn btn-primary">
                    <i class="fas fa-plus me-1"></i>
                    Create New Project
                </a>
            </div>
            <div class="card-body">
                @if (Model.Projects.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-striped table-hover">
                            <thead class="table-dark">
                                <tr>
                                    <th>Title</th>
                                    <th>Status</th>
                                    <th>Progress</th>
                                    <th>Target Amount</th>
                                    <th>Raised Amount</th>
                                    <th>Start Date</th>
                                    <th>Target Date</th>
                                    <th>Featured</th>
                                    <th>Active</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var project in Model.Projects.OrderByDescending(p => p.CreatedDate))
                                {
                                    <tr data-project-id="@project.Id">
                                        <td>
                                            <div>
                                                <strong>@project.Title</strong>
                                                @if (!string.IsNullOrEmpty(project.Location))
                                                {
                                                    <br><small class="text-muted"><i class="fas fa-map-marker-alt"></i> @project.Location</small>
                                                }
                                            </div>
                                        </td>
                                        <td>
                                            <span class="badge @(project.Status switch {
                                                "Planning" => "bg-secondary",
                                                "Fundraising" => "bg-info",
                                                "Construction" => "bg-warning",
                                                "Completed" => "bg-success",
                                                _ => "bg-secondary"
                                            })">
                                                @project.Status
                                            </span>
                                        </td>
                                        <td>
                                            <div class="progress mb-1" style="height: 20px;">
                                                <div class="progress-bar @(project.ProgressPercentage >= 100 ? "bg-success" : project.ProgressPercentage >= 75 ? "bg-info" : project.ProgressPercentage >= 50 ? "bg-warning" : "bg-danger")" 
                                                     role="progressbar" 
                                                     style="width: @Math.Min(project.ProgressPercentage, 100)%"
                                                     aria-valuenow="@project.ProgressPercentage" 
                                                     aria-valuemin="0" 
                                                     aria-valuemax="100">
                                                    @project.ProgressPercentage%
                                                </div>
                                            </div>
                                        </td>
                                        <td class="text-end">$@project.TargetAmount.ToString("N2")</td>
                                        <td class="text-end">$@project.CurrentAmount.ToString("N2")</td>
                                        <td>@project.StartDate.ToString("MMM dd, yyyy")</td>
                                        <td>
                                            @if (project.TargetCompletionDate.HasValue)
                                            {
                                                @project.TargetCompletionDate.Value.ToString("MMM dd, yyyy")
                                                if (project.DaysRemaining > 0)
                                                {
                                                    <br><small class="text-muted">(@project.DaysRemaining days left)</small>
                                                }
                                            }
                                            else
                                            {
                                                <text>-</text>
                                            }
                                        </td>
                                        <td>
                                            <button class="btn btn-sm @(project.IsFeatured ? "btn-warning" : "btn-outline-warning") toggle-featured" 
                                                    data-id="@project.Id" 
                                                    data-featured="@project.IsFeatured.ToString().ToLower()">
                                                <i class="fas fa-star"></i>
                                            </button>
                                        </td>
                                        <td>
                                            <button class="btn btn-sm @(project.IsActive ? "btn-success" : "btn-danger") toggle-status" 
                                                    data-id="@project.Id" 
                                                    data-active="@project.IsActive.ToString().ToLower()">
                                                <i class="fas @(project.IsActive ? "fa-check" : "fa-times")"></i>
                                            </button>
                                        </td>
                                        <td>
                                            <div class="btn-group" role="group">
                                                <button type="button" class="btn btn-sm btn-info view-details" 
                                                        data-id="@project.Id" 
                                                        data-bs-toggle="modal" 
                                                        data-bs-target="#projectDetailsModal">
                                                    <i class="fas fa-eye"></i>
                                                </button>
                                                <a href="@Url.Action("EditProject", new { id = project.Id })" 
                                                   class="btn btn-sm btn-primary">
                                                    <i class="fas fa-edit"></i>
                                                </a>
                                                <button type="button" class="btn btn-sm btn-danger delete-project" 
                                                        data-id="@project.Id" 
                                                        data-title="@project.Title">
                                                    <i class="fas fa-trash"></i>
                                                </button>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="text-center py-5">
                        <i class="fas fa-project-diagram fa-3x text-muted mb-3"></i>
                        <h5 class="text-muted">No projects found</h5>
                        <p class="text-muted">Create your first masjid project to get started.</p>
                        <a href="@Url.Action("CreateProject")" class="btn btn-primary">
                            <i class="fas fa-plus me-1"></i>
                            Create New Project
                        </a>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<!-- Project Details Modal -->
<div class="modal fade" id="projectDetailsModal" tabindex="-1" aria-labelledby="projectDetailsModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="projectDetailsModalLabel">
                    <i class="fas fa-info-circle me-2"></i>
                    Project Details
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body" id="projectDetailsContent">
                <!-- Content will be loaded here -->
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            // View project details
            $('.view-details').on('click', function() {
                const projectId = $(this).data('id');
                
                $.get('@Url.Action("ProjectDetails")', { id: projectId })
                    .done(function(data) {
                        $('#projectDetailsContent').html(data);
                    })
                    .fail(function() {
                        showAlert('Failed to load project details', 'error');
                    });
            });

            // Toggle project status
            $('.toggle-status').on('click', function() {
                const button = $(this);
                const projectId = button.data('id');
                const isActive = button.data('active');
                
                $.post('@Url.Action("ToggleProjectStatus")', {
                    id: projectId,
                    __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
                })
                .done(function(response) {
                    if (response.success) {
                        const newStatus = response.isActive;
                        button.data('active', newStatus);
                        button.removeClass('btn-success btn-danger');
                        button.addClass(newStatus ? 'btn-success' : 'btn-danger');
                        button.find('i').removeClass('fa-check fa-times');
                        button.find('i').addClass(newStatus ? 'fa-check' : 'fa-times');
                        
                        showAlert(response.message, 'success');
                    } else {
                        showAlert(response.message, 'error');
                    }
                })
                .fail(function() {
                    showAlert('Failed to update project status', 'error');
                });
            });

            // Toggle featured status
            $('.toggle-featured').on('click', function() {
                const button = $(this);
                const projectId = button.data('id');
                const isFeatured = button.data('featured');
                
                $.post('@Url.Action("ToggleFeaturedProject")', {
                    id: projectId,
                    __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
                })
                .done(function(response) {
                    if (response.success) {
                        // Update all featured buttons
                        $('.toggle-featured').each(function() {
                            const btn = $(this);
                            const btnId = btn.data('id');
                            
                            if (btnId == projectId) {
                                btn.data('featured', response.isFeatured);
                                btn.removeClass('btn-warning btn-outline-warning');
                                btn.addClass(response.isFeatured ? 'btn-warning' : 'btn-outline-warning');
                            } else if (response.isFeatured) {
                                // Unset other featured projects
                                btn.data('featured', false);
                                btn.removeClass('btn-warning btn-outline-warning');
                                btn.addClass('btn-outline-warning');
                            }
                        });
                        
                        showAlert(response.message, 'success');
                    } else {
                        showAlert(response.message, 'error');
                    }
                })
                .fail(function() {
                    showAlert('Failed to update featured status', 'error');
                });
            });

            // Delete project
            $('.delete-project').on('click', function() {
                const projectId = $(this).data('id');
                const projectTitle = $(this).data('title');
                
                if (confirm(`Are you sure you want to delete the project "${projectTitle}"? This action cannot be undone.`)) {
                    $.post('@Url.Action("DeleteProject")', {
                        id: projectId,
                        __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
                    })
                    .done(function(response) {
                        if (response.success) {
                            $(`tr[data-project-id="${projectId}"]`).fadeOut(function() {
                                $(this).remove();
                            });
                            showAlert(response.message, 'success');
                        } else {
                            showAlert(response.message, 'error');
                        }
                    })
                    .fail(function() {
                        showAlert('Failed to delete project', 'error');
                    });
                }
            });
        });

        function showAlert(message, type) {
            const alertClass = type === 'success' ? 'alert-success' : 'alert-danger';
            const alertHtml = `
                <div class="alert ${alertClass} alert-dismissible fade show" role="alert">
                    ${message}
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            `;
            
            $('.card-body').first().prepend(alertHtml);
            
            // Auto-dismiss after 5 seconds
            setTimeout(function() {
                $('.alert').fadeOut();
            }, 5000);
        }
    </script>
}