@model GambianMuslimCommunity.Models.Member
@{
    ViewData["Title"] = "Check Membership Status";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<main class="main-content">
    <!-- Hero Section -->
    <section class="hero-section bg-gradient py-5" style="background: linear-gradient(135deg, #1a4c5c 0%, #2d6e42 100%);">
        <div class="container">
            <div class="row justify-content-center text-center">
                <div class="col-lg-8">
                    <h1 class="text-white mb-4" style="font-size: 2.5rem; font-weight: 700;">
                        <i class="fas fa-search text-success me-3"></i>
                        Check Membership Status
                    </h1>
                    <p class="text-white-75 mb-0" style="font-size: 1.1rem; opacity: 0.9;">
                        Enter your email address to check the status of your membership application
                    </p>
                </div>
            </div>
        </div>
    </section>

    <!-- Status Check Section -->
    <section class="py-5" style="background-color: #f8f9fa;">
        <div class="container">
            <div class="row justify-content-center">
                <div class="col-lg-6">
                    @if (ViewBag.ErrorMessage != null)
                    {
                        <div class="alert alert-warning border-0 shadow-sm">
                            <i class="fas fa-exclamation-triangle me-2"></i>
                            @ViewBag.ErrorMessage
                        </div>
                    }
                    
                    @if (Model == null)
                    {
                        <!-- Search Form -->
                        <div class="card shadow border-0">
                            <div class="card-header bg-success text-white">
                                <h4 class="card-title mb-0">
                                    <i class="fas fa-envelope me-2"></i>
                                    Enter Your Email
                                </h4>
                            </div>
                            <div class="card-body p-4">
                                <form asp-action="Status" method="post">
                                    <div class="mb-3">
                                        <label for="email" class="form-label fw-bold">Email Address</label>
                                        <input type="email" class="form-control form-control-lg" id="email" name="email" 
                                               placeholder="Enter the email used for registration" required />
                                        <div class="form-text">
                                            Enter the same email address you used when registering for membership.
                                        </div>
                                    </div>
                                    
                                    <div class="d-grid">
                                        <button type="submit" class="btn btn-success btn-lg">
                                            <i class="fas fa-search me-2"></i>
                                            Check Status
                                        </button>
                                    </div>
                                </form>
                            </div>
                        </div>
                        
                        <!-- Info Cards -->
                        <div class="row mt-4">
                            <div class="col-md-6 mb-3">
                                <div class="card border-0 shadow-sm h-100">
                                    <div class="card-body text-center p-3">
                                        <i class="fas fa-user-plus text-primary mb-2" style="font-size: 2rem;"></i>
                                        <h6 class="card-title">New Member?</h6>
                                        <p class="card-text small text-muted">Register for community membership</p>
                                        <a href="/Membership/Register" class="btn btn-outline-primary btn-sm">Register Now</a>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-6 mb-3">
                                <div class="card border-0 shadow-sm h-100">
                                    <div class="card-body text-center p-3">
                                        <i class="fas fa-users text-success mb-2" style="font-size: 2rem;"></i>
                                        <h6 class="card-title">Active Members</h6>
                                        <p class="card-text small text-muted">View our community directory</p>
                                        <a href="/Membership/Directory" class="btn btn-outline-success btn-sm">View Directory</a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                    else
                    {
                        <!-- Member Status Display -->
                        <div class="card shadow border-0">
                            <div class="card-header bg-primary text-white">
                                <h4 class="card-title mb-0">
                                    <i class="fas fa-user me-2"></i>
                                    Membership Status
                                </h4>
                            </div>
                            <div class="card-body p-4">
                                <!-- Member Information -->
                                <div class="row mb-4">
                                    <div class="col-md-8">
                                        <h5 class="text-primary mb-2">@Model.FullName</h5>
                                        <p class="text-muted mb-1">
                                            <i class="fas fa-envelope me-2"></i>
                                            @Model.Email
                                        </p>
                                        <p class="text-muted mb-1">
                                            <i class="fas fa-phone me-2"></i>
                                            @Model.PhoneNumber
                                        </p>
                                        <p class="text-muted mb-0">
                                            <i class="fas fa-calendar me-2"></i>
                                            Registered: @Model.RegistrationDate.ToString("MMMM dd, yyyy")
                                        </p>
                                    </div>
                                    <div class="col-md-4 text-end">
                                        <!-- Status Badge -->
                                        @switch (Model.MembershipStatus)
                                        {
                                            case "Pending":
                                                <span class="badge bg-warning rounded-pill fs-6 px-3 py-2">
                                                    <i class="fas fa-clock me-1"></i>
                                                    Pending Review
                                                </span>
                                                break;
                                            case "Active":
                                                <span class="badge bg-success rounded-pill fs-6 px-3 py-2">
                                                    <i class="fas fa-check-circle me-1"></i>
                                                    Active Member
                                                </span>
                                                break;
                                            case "Suspended":
                                                <span class="badge bg-danger rounded-pill fs-6 px-3 py-2">
                                                    <i class="fas fa-pause-circle me-1"></i>
                                                    Suspended
                                                </span>
                                                break;
                                            case "Rejected":
                                                <span class="badge bg-secondary rounded-pill fs-6 px-3 py-2">
                                                    <i class="fas fa-times-circle me-1"></i>
                                                    Application Rejected
                                                </span>
                                                break;
                                            default:
                                                <span class="badge bg-light text-dark rounded-pill fs-6 px-3 py-2">
                                                    @Model.MembershipStatus
                                                </span>
                                                break;
                                        }
                                    </div>
                                </div>

                                <!-- Status Information -->
                                <div class="status-info">
                                    @switch (Model.MembershipStatus)
                                    {
                                        case "Pending":
                                            <div class="alert alert-info border-0">
                                                <div class="d-flex align-items-start">
                                                    <i class="fas fa-info-circle me-3 mt-1"></i>
                                                    <div>
                                                        <h6 class="alert-heading">Application Under Review</h6>
                                                        <p class="mb-2">
                                                            Assalamu Alaikum! Your membership application is currently being reviewed by our community administrators. 
                                                            This process typically takes 3-5 business days.
                                                        </p>
                                                        <p class="mb-0">
                                                            <strong>What's next:</strong> You'll receive an email notification once a decision has been made regarding your application.
                                                        </p>
                                                    </div>
                                                </div>
                                            </div>
                                            break;
                                        case "Active":
                                            <div class="alert alert-success border-0">
                                                <div class="d-flex align-items-start">
                                                    <i class="fas fa-check-circle me-3 mt-1"></i>
                                                    <div>
                                                        <h6 class="alert-heading">Welcome to Our Community!</h6>
                                                        <p class="mb-2">
                                                            Barakallahu feek! Your membership has been approved and you are now an active member of our community.
                                                        </p>
                                                        @if (Model.ApprovedDate.HasValue)
                                                        {
                                                            <p class="mb-0">
                                                                <strong>Member since:</strong> @Model.ApprovedDate.Value.ToString("MMMM yyyy")
                                                            </p>
                                                        }
                                                    </div>
                                                </div>
                                            </div>
                                            break;
                                        case "Suspended":
                                            <div class="alert alert-warning border-0">
                                                <div class="d-flex align-items-start">
                                                    <i class="fas fa-exclamation-triangle me-3 mt-1"></i>
                                                    <div>
                                                        <h6 class="alert-heading">Membership Suspended</h6>
                                                        <p class="mb-2">
                                                            Your membership has been temporarily suspended. Please contact our administrators for more information.
                                                        </p>
                                                        <p class="mb-0">
                                                            <strong>Contact:</strong> For questions, please reach out to our community leaders through the contact form.
                                                        </p>
                                                    </div>
                                                </div>
                                            </div>
                                            break;
                                        case "Rejected":
                                            <div class="alert alert-secondary border-0">
                                                <div class="d-flex align-items-start">
                                                    <i class="fas fa-info-circle me-3 mt-1"></i>
                                                    <div>
                                                        <h6 class="alert-heading">Application Not Approved</h6>
                                                        <p class="mb-2">
                                                            Unfortunately, your membership application was not approved at this time. 
                                                            You are welcome to reapply or contact our administrators for more information.
                                                        </p>
                                                        <p class="mb-0">
                                                            <strong>Reapply:</strong> You may submit a new application after addressing any concerns mentioned in our communication.
                                                        </p>
                                                    </div>
                                                </div>
                                            </div>
                                            break;
                                    }
                                </div>

                                @if (!string.IsNullOrEmpty(Model.Notes))
                                {
                                    <div class="mt-4">
                                        <h6 class="text-muted">Additional Notes:</h6>
                                        <div class="bg-light p-3 rounded">
                                            @Model.Notes
                                        </div>
                                    </div>
                                }

                                <!-- Action Buttons -->
                                <div class="d-flex gap-2 mt-4 flex-wrap">
                                    <a href="/" class="btn btn-primary">
                                        <i class="fas fa-home me-1"></i>
                                        Back to Home
                                    </a>
                                    @if (Model.MembershipStatus == "Active")
                                    {
                                        <a href="/Membership/Directory" class="btn btn-outline-success">
                                            <i class="fas fa-users me-1"></i>
                                            View Directory
                                        </a>
                                    }
                                    <a href="/Home/Contact" class="btn btn-outline-secondary">
                                        <i class="fas fa-envelope me-1"></i>
                                        Contact Us
                                    </a>
                                    <button type="button" class="btn btn-outline-info" onclick="checkAnother()">
                                        <i class="fas fa-search me-1"></i>
                                        Check Another
                                    </button>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </section>
</main>

<script>
    function checkAnother() {
        window.location.href = '/Membership/Status';
    }
    
    document.addEventListener('DOMContentLoaded', function() {
        // Auto-focus email input
        const emailInput = document.getElementById('email');
        if (emailInput) {
            emailInput.focus();
        }
        
        // Form enhancement
        const form = document.querySelector('form');
        if (form) {
            form.addEventListener('submit', function(e) {
                const submitBtn = form.querySelector('button[type="submit"]');
                const originalText = submitBtn.innerHTML;
                submitBtn.innerHTML = '<i class="fas fa-spinner fa-spin me-2"></i>Searching...';
                submitBtn.disabled = true;
                
                // Re-enable after delay if form is invalid
                setTimeout(() => {
                    if (submitBtn.disabled) {
                        submitBtn.innerHTML = originalText;
                        submitBtn.disabled = false;
                    }
                }, 5000);
            });
        }
    });
</script>

<style>
    .text-white-75 {
        color: rgba(255, 255, 255, 0.75);
    }
    
    .card {
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }
    
    .card:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 25px rgba(0,0,0,0.1) !important;
    }
    
    .hero-section {
        position: relative;
        overflow: hidden;
    }
    
    .hero-section::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: url('/images/islamic-pattern.png') repeat;
        opacity: 0.1;
        z-index: 0;
    }
    
    .hero-section > .container {
        position: relative;
        z-index: 1;
    }
    
    @@media (max-width: 768px) {
        .hero-section h1 {
            font-size: 2rem !important;
        }
        
        .d-flex.gap-2 {
            flex-direction: column;
        }
        
        .d-flex.gap-2 .btn {
            margin-bottom: 0.5rem;
        }
    }
</style>